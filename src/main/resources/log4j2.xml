<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</Property>
        <Property name="LOG_DIR">target/logs</Property>
    </Properties>

    <Appenders>
        <!-- Consola -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        <!-- Archivo de log general -->
        <RollingFile name="File" fileName="${LOG_DIR}/automation.log"
                     filePattern="${LOG_DIR}/automation-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>

        <!-- Archivo de log para errores -->
        <RollingFile name="ErrorFile" fileName="${LOG_DIR}/error.log"
                     filePattern="${LOG_DIR}/error-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="5"/>
        </RollingFile>

        <!-- Archivo de log para pruebas -->
        <RollingFile name="TestFile" fileName="${LOG_DIR}/tests.log"
                     filePattern="${LOG_DIR}/tests-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>

        <!-- Archivo JSON para integración con herramientas -->
        <RollingFile name="JsonFile" fileName="${LOG_DIR}/automation.json"
                     filePattern="${LOG_DIR}/automation-%d{yyyy-MM-dd}-%i.json">
            <JsonLayout complete="false" compact="true" eventEol="true"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="5"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Logger específico para pruebas -->
        <Logger name="com.automation.tests" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="TestFile"/>
            <AppenderRef ref="File"/>
        </Logger>

        <!-- Logger para listeners -->
        <Logger name="com.automation.listeners" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="TestFile"/>
            <AppenderRef ref="File"/>
        </Logger>

        <!-- Logger para pages -->
        <Logger name="com.automation.pages" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Logger>

        <!-- Logger para servicios API -->
        <Logger name="com.automation.services" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Logger>

        <!-- Logger para Rest Assured -->
        <Logger name="io.restassured" level="WARN" additivity="false">
            <AppenderRef ref="File"/>
        </Logger>

        <!-- Logger para Selenium -->
        <Logger name="org.openqa.selenium" level="WARN" additivity="false">
            <AppenderRef ref="File"/>
        </Logger>

        <!-- Logger raíz -->
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
            <AppenderRef ref="ErrorFile"/>
            <AppenderRef ref="JsonFile"/>
        </Root>
    </Loggers>
</Configuration>
