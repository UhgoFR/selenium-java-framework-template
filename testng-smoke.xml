<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Test Suite" parallel="classes" thread-count="3">
    
    <listeners>
        <listener class-name="com.automation.listeners.ExtentReportListener"/>
        <listener class-name="com.automation.listeners.AnnotationTransformer"/>
    </listeners>
    
    <parameter name="browser" value="chrome"/>
    <parameter name="environment" value="test"/>
    <parameter name="headless" value="false"/>
    
    <!-- 
    ============================================
    SMOKE TESTS - Quick validation tests
    ============================================
    Purpose: Fast sanity checks to verify critical functionality
    Execution time: ~2-5 minutes
    When to run: After every build, before deployment
    
    NOTE: Including only specific smoke tests without DataProviders
    for faster execution and more predictable results
    -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
                <!-- Exclude tests with DataProviders for faster smoke execution -->
                <exclude name="regression"/>
            </run>
        </groups>
        <classes>
            <!-- Only include LoginTests smoke tests -->
            <class name="com.automation.tests.web.SauceDemo.LoginTests">
                <methods>
                    <!-- Only include specific smoke methods without DataProviders -->
                    <include name="testLoginPageElements"/>
                </methods>
            </class>
            
            <!-- Only include InventoryTests smoke tests -->
            <class name="com.automation.tests.web.SauceDemo.InventoryTests">
                <methods>
                    <!-- Only include specific smoke methods without DataProviders -->
                    <include name="testInventoryPageLoaded"/>
                    <include name="testProductInformationDisplayed"/>
                </methods>
            </class>
            
            <!-- Exclude CheckoutTests from smoke (they are more integration tests) -->
            
            <!-- Only include specific SauceDemoTestSuite smoke tests -->
            <class name="com.automation.tests.web.SauceDemo.SauceDemoTestSuite">
                <methods>
                    <!-- Only include critical smoke tests -->
                    <include name="testValidLogin"/>
                    <include name="testProductCatalogDisplay"/>
                    <include name="testSystemLogout"/>
                </methods>
            </class>
        </classes>
    </test>
    
</suite>
